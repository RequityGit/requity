{
  "permissions": {
    "allow": [
      "Bash(pnpm typecheck)",
      "Bash(pnpm lint)",
      "Bash(pnpm build)",
      "Bash(pnpm test*)",
      "Bash(pnpm dev*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(git checkout*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git push*)",
      "Bash(git fetch*)",
      "Bash(git pull*)",
      "Bash(git merge*)",
      "Bash(git stash*)",
      "Bash(git rebase*)",
      "Bash(git remote*)",
      "Bash(git rev-parse*)",
      "Bash(git show*)",
      "Bash(npx supabase*)",
      "Bash(ls*)",
      "Bash(mkdir*)",
      "Bash(mv dev/*)",
      "Bash(cat*)",
      "Bash(wc*)",
      "Bash(head*)",
      "Bash(tail*)",
      "Bash(which*)",
      "Bash(echo*)",
      "Bash(node*)",
      "Bash(npx tsc*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/check-netlify-deploy.sh",
            "asyncRewake": true,
            "timeout": 660,
            "statusMessage": "Waiting to check Netlify deploy..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/check-sentry-errors.sh",
            "asyncRewake": true,
            "timeout": 30
          }
        ]
      }
    ]
  },
  "enableAllProjectMcpServers": true
}
