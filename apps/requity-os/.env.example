NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Gmail OAuth (required for Gmail integration — separate from portal login Google OAuth)
GMAIL_CLIENT_ID=               # Gmail OAuth Client ID (from Google Cloud Console, with Gmail API scopes)
GMAIL_CLIENT_SECRET=           # Gmail OAuth Client Secret (server-side only)
# Local dev: set to http://localhost:3000 so nothing in the app assumes production.
# Production: https://app.requitygroup.com (Netlify / netlify.toml)
NEXT_PUBLIC_APP_URL=

# IMPORTANT: For local Google OAuth and magic links, Supabase must allow your dev origin.
# Supabase Dashboard → Authentication → URL Configuration:
# - Add to "Redirect URLs" (exact or wildcard): http://localhost:3000/** and http://127.0.0.1:3000/**
# - Example paths: http://localhost:3000/auth/callback  http://localhost:3000/auth/confirm
# If localhost is not listed, the project "Site URL" (often production) is used after OAuth
# and you will land on app.requitygroup.com instead of local.

# Sentry
SENTRY_DSN=                    # Sentry DSN for error tracking (server/edge)
NEXT_PUBLIC_SENTRY_DSN=        # Sentry DSN for error tracking (client-side, exposed to browser)
SENTRY_AUTH_TOKEN=             # Sentry auth token for source map uploads (CI/CD only)

# Email (Nodemailer — public marketing site forms)
SMTP_HOST=                     # SMTP server host (e.g. smtp.gmail.com)
SMTP_PORT=587                  # SMTP port (587 for TLS, 465 for SSL)
SMTP_USER=                     # SMTP username / sending email address
SMTP_PASS=                     # SMTP password or app password
NOTIFY_EMAIL=                  # Internal email to receive loan request notifications
INVESTOR_NOTIFY_EMAIL=         # Internal email to receive investor request notifications
INVESTOR_CONTACT_EMAIL=        # Investor relations contact email (shown in confirmation emails)

# Public site integrations
NEXT_PUBLIC_GOOGLE_PLACES_API_KEY=   # Google Places API key (address autocomplete on apply page)
FRED_API_KEY=                        # FRED API key for loan market indexes (free: https://fred.stlouisfed.org/docs/api/api_key.html)
WEBFLOW_API_TOKEN=                   # Webflow API token for CMS integration
WEBFLOW_SITE_ID=                     # Webflow site ID
GOOGLE_SHEETS_API_KEY=               # Google Sheets API key (pricing sync)
PRICING_SHEET_ID=                    # Google Sheet ID for pricing matrix
PRICING_SHEET_TAB=Pricing Matrix     # Sheet tab name
SYNC_PRICING_SECRET=                 # Webhook secret for Make.com pricing sync
INTAKE_WEBHOOK_SECRET=               # Webhook secret for Make.com deal intake (falls back to CRON_SECRET)

# AI Document Review
ANTHROPIC_API_KEY=                   # Anthropic API key for AI document review (Claude)
