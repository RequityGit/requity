new file mode 100644
index 0000000..d1d280b
--- /dev/null
+++ b/apps/requity-os/hooks/useConditionDrivenFields.ts
@@ -0,0 +1,217 @@
+"use client";
+
+import { useState, useEffect, useCallback, useMemo } from "react";
+import { createClient } from "@/lib/supabase/client";
+import type { UwFieldDef, UwFieldObject } from "@/components/pipeline-v2/pipeline-types";
+import {
+  isVisible,
+  type VisibilityCondition,
+  type VisibilityContext,
+} from "@/lib/visibility-engine";
+import type { ConditionalRule, FieldPermissions } from "@/hooks/useFieldConfigurations";
+
+// ─── Types ───
+
+interface FieldConfigRecord {
+  id: string;
+  module: string;
+  field_key: string;
+  field_label: string;
+  field_type: string;
+  is_visible: boolean;
+  is_archived: boolean;
+  dropdown_options: string[] | null;
+  visibility_condition: VisibilityCondition | null;
+  formula_expression: string | null;
+  formula_output_format: string | null;
+  formula_decimal_places: number | null;
+  conditional_rules: ConditionalRule[] | null;
+  permissions: FieldPermissions | null;
+  required_at_stage: string | null;
+  blocks_stage_progression: boolean | null;
+}
+
+/**
+ * Map field_configurations field_type to UwFieldDef type.
+ */
+function mapFieldType(fcType: string): UwFieldDef["type"] {
+  switch (fcType) {
+    case "percentage":
+      return "percent";
+    case "dropdown":
+      return "select";
+    case "currency":
+    case "number":
+    case "text":
+    case "boolean":
+    case "date":
+      return fcType as UwFieldDef["type"];
+    default:
+      return "text";
+  }
+}
+
+// ─── Cache ───
+
+const SELECT_COLS = [
+  "id",
+  "module",
+  "field_key",
+  "field_label",
+  "field_type",
+  "is_visible",
+  "is_archived",
+  "dropdown_options",
+  "visibility_condition",
+  "formula_expression",
+  "formula_output_format",
+  "formula_decimal_places",
+  "conditional_rules",
+  "permissions",
+  "required_at_stage",
+  "blocks_stage_progression",
+].join(", ");
+
+// Modules that feed pipeline deal tabs
+const PIPELINE_MODULES = [
+  "uw_deal",
+  "uw_property",
+  "uw_borrower",
+] as const;
+
+let pipelineFieldCache: {
+  data: FieldConfigRecord[];
+  timestamp: number;
+} | null = null;
+const CACHE_TTL = 5 * 60 * 1000; // 5 minutes
+
+/**
+ * Invalidate the pipeline field config cache.
+ * Call after Object Manager publishes changes.
+ */
+export function invalidateConditionFieldCache() {
+  pipelineFieldCache = null;
+}
+
+// ─── Hook ───
+
+export interface ConditionDrivenFieldsResult {
+  /** UW deal fields filtered by conditions */
+  uwFields: UwFieldDef[];
+  /** Property fields filtered by conditions */
+  propertyFields: UwFieldDef[];
+  /** Borrower/contact fields filtered by conditions */
+  contactFields: UwFieldDef[];
+  /** Whether field configs are still loading */
+  isLoading: boolean;
+}
+
+/**
+ * Fetches ALL pipeline field_configurations (uw_deal, uw_property, uw_borrower)
+ * and filters them by the deal's visibility context (asset_class x loan_type).
+ *
+ * This replaces useResolvedCardType for field selection -- no card type needed.
+ * The conditions on each field (set via Object Manager) determine visibility.
+ */
+export function useConditionDrivenFields(
+  visibilityContext: VisibilityContext
+): ConditionDrivenFieldsResult {
+  const [fieldConfigs, setFieldConfigs] = useState<FieldConfigRecord[]>([]);
+  const [isLoading, setIsLoading] = useState(true);
+
+  const fetchConfigs = useCallback(async () => {
+    // Check cache
+    if (pipelineFieldCache && Date.now() - pipelineFieldCache.timestamp < CACHE_TTL) {
+      setFieldConfigs(pipelineFieldCache.data);
+      setIsLoading(false);
+      return;
+    }
+
+    try {
+      const supabase = createClient();
+      const { data, error } = await supabase
+        .from("field_configurations")
+        .select(SELECT_COLS)
+        .in("module", [...PIPELINE_MODULES])
+        .eq("is_visible", true)
+        .eq("is_archived", false)
+        .order("field_label", { ascending: true });
+
+      if (error || !data) {
+        setIsLoading(false);
+        return;
+      }
+
+      const records = data as unknown as FieldConfigRecord[];
+      pipelineFieldCache = { data: records, timestamp: Date.now() };
+      setFieldConfigs(records);
+    } catch {
+      // Silent fallback
+    } finally {
+      setIsLoading(false);
+    }
+  }, []);
+
+  useEffect(() => {
+    fetchConfigs();
+  }, [fetchConfigs]);
+
+  // Stable context key to avoid re-computation
+  const ctxKey = `${visibilityContext.asset_class}:${visibilityContext.loan_type}`;
+
+  const result = useMemo<ConditionDrivenFieldsResult>(() => {
+    if (isLoading || fieldConfigs.length === 0) {
+      return { uwFields: [], propertyFields: [], contactFields: [], isLoading };
+    }
+
+    const uwFields: UwFieldDef[] = [];
+    const propertyFields: UwFieldDef[] = [];
+    const contactFields: UwFieldDef[] = [];
+
+    for (const fc of fieldConfigs) {
+      // Filter by visibility conditions
+      if (!isVisible(fc.visibility_condition, visibilityContext)) {
+        continue;
+      }
+
+      const isFormula = fc.field_type === "formula" && fc.formula_expression;
+
+      const fieldDef: UwFieldDef = {
+        key: fc.field_key,
+        label: fc.field_label,
+        type: isFormula
+          ? mapFieldType(fc.formula_output_format ?? "number")
+          : mapFieldType(fc.field_type),
+        options: fc.dropdown_options ?? undefined,
+        // Derive object from module
+        object: fc.module === "uw_property"
+          ? "property"
+          : fc.module === "uw_borrower"
+            ? "borrower"
+            : "deal" as UwFieldObject,
+        ...(isFormula && {
+          formulaExpression: fc.formula_expression!,
+          formulaOutputFormat: (fc.formula_output_format ?? "number") as UwFieldDef["formulaOutputFormat"],
+          formulaDecimalPlaces: fc.formula_decimal_places ?? 2,
+        }),
+      };
+
+      switch (fc.module) {
+        case "uw_deal":
+          uwFields.push(fieldDef);
+          break;
+        case "uw_property":
+          propertyFields.push(fieldDef);
+          break;
+        case "uw_borrower":
+          contactFields.push(fieldDef);
+          break;
+      }
+    }
+
+    return { uwFields, propertyFields, contactFields, isLoading: false };
+    // eslint-disable-next-line react-hooks/exhaustive-deps
+  }, [fieldConfigs, isLoading, ctxKey]);
+
+  return result;
+}
diff --git a/apps/requity-os/hooks/useDealConfig.ts b/apps/requity-os/hooks/useDealConfig.ts
new file mode 100644
index 0000000..f51a86f
--- /dev/null
+++ b/apps/requity-os/hooks/useDealConfig.ts
@@ -0,0 +1,181 @@
+"use client";
+
+import { useState, useEffect, useCallback, useMemo } from "react";
+import { createClient } from "@/lib/supabase/client";
+import type { UwOutputDef, CardMetricDef } from "@/components/pipeline-v2/pipeline-types";
+import type { VisibilityContext } from "@/lib/visibility-engine";
+
+// ─── Types ───
+
+export interface DealConfigTemplate {
+  id: string;
+  label: string;
+  slug: string;
+  capital_side: string;
+  asset_class_condition: string[] | null;
+  loan_type_condition: string[] | null;
+  uw_outputs: UwOutputDef[];
+  card_metrics: CardMetricDef[];
+  contact_roles: string[];
+}
+
+export interface DealConfig {
+  /** Best matching config template */
+  template: DealConfigTemplate | null;
+  /** UW output definitions for this deal context */
+  uwOutputs: UwOutputDef[];
+  /** Pipeline card metric definitions */
+  cardMetrics: CardMetricDef[];
+  /** Contact roles */
+  contactRoles: string[];
+  /** Deal type label derived from config */
+  dealTypeLabel: string;
+  /** Loading state */
+  isLoading: boolean;
+}
+
+// ─── Cache ───
+
+let configCache: {
+  data: DealConfigTemplate[];
+  timestamp: number;
+} | null = null;
+const CACHE_TTL = 5 * 60 * 1000;
+
+export function invalidateDealConfigCache() {
+  configCache = null;
+}
+
+// ─── Matching Logic ───
+
+/**
+ * Score how well a config template matches a visibility context.
+ * Higher score = better match. -1 = no match.
+ */
+function matchScore(
+  template: DealConfigTemplate,
+  context: VisibilityContext,
+  capitalSide?: string
+): number {
+  let score = 0;
+
+  // Asset class match
+  if (template.asset_class_condition && template.asset_class_condition.length > 0) {
+    if (template.asset_class_condition.includes(context.asset_class)) {
+      score += 10;
+    } else {
+      return -1; // Hard mismatch
+    }
+  }
+
+  // Loan type match
+  if (template.loan_type_condition && template.loan_type_condition.length > 0) {
+    if (context.loan_type && template.loan_type_condition.includes(context.loan_type)) {
+      score += 20; // Loan type is more specific
+    } else if (context.loan_type) {
+      return -1; // Hard mismatch
+    }
+    // If deal has no loan_type yet, don't penalize
+  }
+
+  // Capital side match (bonus, not hard filter)
+  if (capitalSide && template.capital_side === capitalSide) {
+    score += 5;
+  }
+
+  return score;
+}
+
+// ─── Hook ───
+
+/**
+ * Fetches deal_config_templates and returns the best match for the given
+ * visibility context (asset_class x loan_type).
+ *
+ * This replaces the uw_outputs/card_metrics that previously lived on card types.
+ */
+export function useDealConfig(
+  visibilityContext: VisibilityContext,
+  capitalSide?: string
+): DealConfig {
+  const [configs, setConfigs] = useState<DealConfigTemplate[]>([]);
+  const [isLoading, setIsLoading] = useState(true);
+
+  const fetchConfigs = useCallback(async () => {
+    if (configCache && Date.now() - configCache.timestamp < CACHE_TTL) {
+      setConfigs(configCache.data);
+      setIsLoading(false);
+      return;
+    }
+
+    try {
+      const supabase = createClient();
+      const { data, error } = await supabase
+        .from("deal_config_templates")
+        .select("*")
+        .eq("status", "active")
+        .order("sort_order");
+
+      if (error || !data) {
+        setIsLoading(false);
+        return;
+      }
+
+      const templates = data as unknown as DealConfigTemplate[];
+      configCache = { data: templates, timestamp: Date.now() };
+      setConfigs(templates);
+    } catch {
+      // Silent fallback
+    } finally {
+      setIsLoading(false);
+    }
+  }, []);
+
+  useEffect(() => {
+    fetchConfigs();
+  }, [fetchConfigs]);
+
+  const ctxKey = `${visibilityContext.asset_class}:${visibilityContext.loan_type}:${capitalSide ?? ""}`;
+
+  const result = useMemo<DealConfig>(() => {
+    if (isLoading || configs.length === 0) {
+      return {
+        template: null,
+        uwOutputs: [],
+        cardMetrics: [],
+        contactRoles: ["borrower"],
+        dealTypeLabel: "Deal",
+        isLoading,
+      };
+    }
+
+    // Find best matching template
+    let bestTemplate: DealConfigTemplate | null = null;
+    let bestScore = -1;
+
+    for (const t of configs) {
+      const score = matchScore(t, visibilityContext, capitalSide);
+      if (score > bestScore) {
+        bestScore = score;
+        bestTemplate = t;
+      }
+    }
+
+    // Fallback: if no match, use first config
+    if (!bestTemplate && configs.length > 0) {
+      bestTemplate = configs[0];
+    }
+
+    return {
+      template: bestTemplate,
+      uwOutputs: bestTemplate?.uw_outputs ?? [],
+      cardMetrics: bestTemplate?.card_metrics ?? [],
+      contactRoles: bestTemplate?.contact_roles ?? ["borrower"],
+      dealTypeLabel: bestTemplate?.label ?? "Deal",
+      isLoading: false,
+    };
+    // eslint-disable-next-line react-hooks/exhaustive-deps
+  }, [configs, isLoading, ctxKey]);
+
+  return result;
+}
