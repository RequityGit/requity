# ============================================================
# Requity Portal — Playwright E2E Test Environment Variables
# ============================================================
# Copy this file to .env.test and fill in real values.
# NEVER commit .env.test with real credentials.
#
#   cp .env.test.example .env.test
#
# ============================================================

# Portal base URL (defaults to production if not set)
PORTAL_BASE_URL=https://portal.requitygroup.com

# Supabase project URL and anon key (for programmatic auth)
SUPABASE_URL=https://edhlkknvlczhbowasjna.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key-here

# ---- Borrower test account ----
BORROWER_EMAIL=borrower-test@example.com
BORROWER_PASSWORD=your-borrower-password-here

# ---- Investor test account ----
INVESTOR_EMAIL=investor-test@example.com
INVESTOR_PASSWORD=your-investor-password-here

# ---- Admin test account (optional, for admin navigation tests) ----
ADMIN_EMAIL=admin-test@example.com
ADMIN_PASSWORD=your-admin-password-here
